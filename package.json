{
  "name": "kaelum",
  "version": "1.4.3",
  "description": "A minimalist Node.js framework for building web pages and APIs with simplicity and speed.",
  "main": "index.js",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js"
    }
  },
  "bin": {
    "kaelum": "cli/index.js"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --verbose",
    "release": "standard-version",
    "changelog": "standard-version --skip.bump --skip.tag --skip.commit"
  },
  "keywords": [
    "framework",
    "nodejs",
    "express",
    "cli",
    "kaelum",
    "api",
    "web",
    "minimal",
    "starter"
  ],
  "author": "Matheus Campagnolo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaelumjs/kaelum.git"
  },
  "bugs": {
    "url": "https://github.com/kaelumjs/kaelum/issues"
  },
  "homepage": "https://github.com/kaelumjs/kaelum#readme",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "fs-extra": "^11.3.0",
    "helmet": "^7.2.0",
    "inquirer": "^12.6.0",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "standard-version": "^9.5.0",
    "supertest": "^7.2.2"
  }
}
